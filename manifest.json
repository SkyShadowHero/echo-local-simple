{
  "id": "echo-local-simple",
  "name": "简单本地音乐",
  "version": "1.0.0",
  "description": "简单实现的本地音乐播放(当前版本在设置里启用在线功能有百分百的风控可能)",
  "author": "天影大侠",
  "icon": "icon.svg",
  "main": "index.js",
  "style": "style.css",
  "runtime": {
    "miniPlayer": false,
    "desktopLyric": false
  },
  "requires": {
    "echoMusicVersion": ">=2.2.6-beta.9"
  },
  "capabilities": {
    "localFiles": true,
    "audioSource": true,
    "kugouApi": true,
    "lyrics": true
  }
}
